{
  "name": "innova/api-laravel",
  "type": "project",
  "description": "Base API-first para la migración del monolito Innova.",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^11.0",
    "laravel/sanctum": "^4.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "pestphp/pest": "^3.0",
    "laravel/pint": "^1.18",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "dev": [
      "php -S 0.0.0.0:8000 -t public"
    ],
    "test": [
      "@php artisan test"
    ]
  }
}
